variable "project"    { default = "drocart" }
variable "env"        { default = "prod" }
variable "aws_region" { default = "ap-south-1" }
variable "vpc_cidr"       { default = "10.0.0.0/16" }
variable "public_cidrs"   { default = ["10.0.1.0/24","10.0.2.0/24"] }
variable "private_cidrs"  { default = ["10.0.11.0/24","10.0.12.0/24"] }
variable "db_cidrs"       { default = ["10.0.21.0/24","10.0.22.0/24"] }
variable "admin_ip"       { default = "0.0.0.0/0" }
variable "key_name"           { default = "drocart-key" }
variable "web_instance_type"  { default = "t3.small" }
variable "app_instance_type"  { default = "t3.medium" }
variable "web_min"     { default = 2 }
variable "web_max"     { default = 6 }
variable "web_desired" { default = 2 }
variable "app_min"     { default = 2 }
variable "app_max"     { default = 8 }
variable "app_desired" { default = 2 }
variable "db_instance_class" { default = "db.t3.medium" }
variable "db_name"           { default = "drocart" }
variable "db_user"           { default = "drocart_admin" }
variable "db_password"       { sensitive = true }
variable "create_replica"    { default = true }
variable "acm_cert_arn"       { default = "" }
variable "domain"             { default = "drocart.com" }
variable "create_hosted_zone" { default = false }
variable "flask_secret_key"      { sensitive = true }
variable "google_client_id"      { default = "" }
variable "google_client_secret"  { sensitive = true; default = "" }
variable "google_redirect_uri"   { default = "https://drocart.com/auth/google/callback" }
variable "alert_email"           { default = "devops@drocart.com" }
